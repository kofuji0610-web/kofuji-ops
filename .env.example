# ==========================================
# コフジ物流 業務管理システム 環境変数
# ==========================================
# リダイレクト URI のポートは PORT と必ず合わせること。
# Google Cloud / Azure の登録 URL も同じポートにすること。

# ─── サーバー設定 ─────────────────────────────────────────────────────────────
# サーバーポート（既定 3000。変更する場合は OAuth リダイレクト URI も合わせる）
PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ─── データベース設定 (MySQL) ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=kofuji_ops

# ─── セキュリティ設定 ─────────────────────────────────────────────────────────
# パスワードハッシュ用のソルト（ランダムな文字列を設定してください）
PASSWORD_SALT=your_random_salt_string_here

# ─── Web Push（VAPID）──────────────────────────────────────────────────────────
# server ディレクトリで: npx web-push generate-vapid-keys
VAPID_EMAIL=your@email.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ─── Google Calendar OAuth ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
# ↑ PORT を変えた場合はここも合わせる

# ─── Microsoft Outlook OAuth ─────────────────────────────────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/auth/microsoft/callback
# ↑ PORT を変えた場合はここも合わせる
MICROSOFT_TENANT_ID=common

# ─── OAuth セキュリティ ───────────────────────────────────────────────────────
# 任意のランダム文字列（未設定時は PASSWORD_SALT を利用）
OAUTH_STATE_SECRET=

# ─── 外部サービス連携 (オプション) ────────────────────────────────────────────
# Manus OAuth 連携用
VITE_APP_ID=your_manus_app_id_here
