# ==========================================
# コフジ物流 業務管理システム 環境変数
# ==========================================

# ─── サーバー設定 ─────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ─── データベース設定 (MySQL) ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=kofuji_ops

# ─── セキュリティ設定 ─────────────────────────────────────────────────────────
# パスワードハッシュ用のソルト（ランダムな文字列を設定してください）
PASSWORD_SALT=your_random_salt_string_here

# ─── 外部サービス連携 (オプション) ────────────────────────────────────────────
# Manus OAuth 連携用
VITE_APP_ID=your_manus_app_id_here
